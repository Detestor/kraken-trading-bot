[Unit]
Description=KrakenBotVPS
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/krakenbot
EnvironmentFile=/opt/krakenbot/.env
ExecStart=/opt/krakenbot/venv/bin/python /opt/krakenbot/bot.py
Restart=always
RestartSec=10
User=krakenbot
Group=krakenbot
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/opt/krakenbot
KillSignal=SIGINT
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
